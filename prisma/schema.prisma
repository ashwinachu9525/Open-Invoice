datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// NextAuth Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(BUSINESS_OWNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  companyId       String?
  passkeyEnabled  Boolean   @default(false)
  passkeyPrompted Boolean   @default(false)
  mfaEnabled      Boolean   @default(false)
  hasSeenTour     Boolean   @default(false)
  mfaSecret       String?
  isBlocked       Boolean   @default(false)
  isPro           Boolean   @default(false)
  proExpiry       DateTime?

  company        Company?        @relation(fields: [companyId], references: [id])
  accounts       Account[]
  sessions       Session[]
  Authenticators Authenticator[]
  auditLogs      AuditLog[]
  aichatSessions AIChatSession[]
  pushSubscriptions PushSubscription[]
  feedbacks      UserFeedback[]

  @@index([companyId])
  @@index([email])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  BUSINESS_OWNER
  STAFF
  USER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// Domain Models
enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

model Company {
  id             String    @id @default(cuid())
  name           String
  gstNumber      String?
  panNumber      String?
  cinNumber      String?
  logo           String?
  address        String?
  state          String?
  email          String?
  phone          String?
  website        String?
  taxPreferences Json?
  invoicePrefix  String?   @default("INV")
  baseCurrency   String?   @default("INR")
  invoiceTemplate String?  @default("modern")
  subscriptionTier SubscriptionTier @default(FREE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  users          User[]
  customers      Customer[]
  invoices       Invoice[]
  quotations     Quotation[]
  bankAccounts   BankAccount[]
  emailSetting   EmailSetting?
  aiSettings     AISettings?
  auditLogs      AuditLog[]
  aichatSessions AIChatSession[]
  catalog        ProductCatalog[]
  emailLogs      EmailLog[]
  reminderConfig ReminderConfig?
  expenses       Expense[]
  feedbacks      UserFeedback[]
  teamInvitations TeamInvitation[]

  @@index([gstNumber])
}

model Customer {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  companyName String?
  gstin       String?
  pan         String?
  address     String?
  state       String?
  country     String?   @default("India")
  email       String?
  phone       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  quotations Quotation[]

  @@index([companyId])
  @@index([name])
  @@index([gstin])
}

model Invoice {
  id                String        @id @default(cuid())
  companyId         String
  customerId        String
  invoiceNumber     String
  date              DateTime
  dueDate           DateTime
  currency          String        @default("INR")
  notes             String?
  terms             String?
  internalNotes     String?
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankAccountType   String?
  themeColor        String?       @default("#1e40af")
  themeFont         String?       @default("Helvetica")
  status            InvoiceStatus @default(DRAFT)
  exchangeRate      Float         @default(1)

  subTotal      Float
  totalDiscount Float   @default(0)
  totalTax      Float
  taxJurisdiction String @default("INDIA_GST")
  cgstAmount    Float   @default(0)
  sgstAmount    Float   @default(0)
  igstAmount    Float   @default(0)
  vatAmount     Float   @default(0)
  tdsPercentage Float   @default(0)
  tdsAmount     Float   @default(0)
  finalAmount   Float
  amountPaid    Float   @default(0)
  balanceDue    Float   @default(0)
  pdfUrl        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]
  payments      Payment[]
  emailLogs     EmailLog[]
  schedule      RecurringSchedule?
  statusHistory InvoiceStatusHistory[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([date])
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

model InvoiceStatusHistory {
  id        String        @id @default(cuid())
  invoiceId String
  status    InvoiceStatus
  note      String?
  createdAt DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceItem {
  id            String  @id @default(cuid())
  invoiceId     String
  description   String
  hsnSac        String?
  quantity      Float
  unitPrice     Float
  discount      Float   @default(0)
  taxPercentage Float   @default(18)
  taxableAmount Float   @default(0)
  taxAmount     Float   @default(0)
  total         Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Float
  paymentMethod PaymentMethod
  transactionId String?
  status        PaymentStatus @default(COMPLETED)
  date          DateTime      @default(now())
  notes         String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

enum PaymentMethod {
  UPI
  BANK_TRANSFER
  RAZORPAY
  STRIPE
  CASH
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model RecurringSchedule {
  id        String             @id @default(cuid())
  invoiceId String             @unique
  frequency RecurringFrequency
  nextRunAt DateTime
  autoSend  Boolean            @default(false)
  status    ScheduleStatus     @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model EmailSetting {
  id                String   @id @default(cuid())
  companyId         String   @unique
  host              String
  port              Int
  username          String
  passwordEncrypted String
  secure            Boolean  @default(true)
  fromEmail         String?
  fromName          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  action    String
  entity    String
  entityId  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([entity, entityId])
}

model BankAccount {
  id            String   @id @default(cuid())
  companyId     String
  bankName      String
  accountName   String
  accountNumber String
  ifscCode      String
  accountType   String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AISettings {
  id            String   @id @default(cuid())
  companyId     String   @unique
  provider      String   @default("gemini")
  geminiKey     String?
  openaiKey     String?
  nvidiaKey     String?
  openrouterKey String?
  fallbackOrder String   @default("gemini,openai,nvidia,openrouter")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AIChatSession {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  title     String   @default("New Invoice Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIChatMessage[]

  @@index([companyId])
  @@index([userId])
}

model AIChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String // "user" | "assistant" | "system"
  content   String
  createdAt DateTime @default(now())

  session AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ProductCatalog {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  description   String?
  hsnSac        String?
  unitPrice     Float
  taxPercentage Float    @default(18)
  unit          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  
  company       Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model EmailLog {
  id          String   @id @default(cuid())
  companyId   String
  invoiceId   String?
  to          String
  subject     String
  status      String   // "sent" | "failed"
  sentAt      DateTime @default(now())
  error       String?
  
  company     Company  @relation(fields: [companyId], references: [id])
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  
  @@index([companyId])
  @@index([invoiceId])
}

model ReminderConfig {
  id            String  @id @default(cuid())
  companyId     String  @unique
  day0Enabled   Boolean @default(true)
  day7Enabled   Boolean @default(true)
  day15Enabled  Boolean @default(false)
  customMessage String?
  
  company       Company @relation(fields: [companyId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  companyId   String
  date        DateTime
  amount      Float
  category    String   // free-text
  description String?
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
}

model Quotation {
  id                String          @id @default(cuid())
  companyId         String
  customerId        String
  quotationNumber   String
  date              DateTime
  expiryDate        DateTime?
  currency          String          @default("INR")
  notes             String?
  terms             String?
  themeColor        String?         @default("#1e40af")
  themeFont         String?         @default("Helvetica")
  status            QuotationStatus @default(DRAFT)
  exchangeRate      Float           @default(1)

  subTotal      Float
  totalDiscount Float   @default(0)
  totalTax      Float
  taxJurisdiction String @default("INDIA_GST")
  cgstAmount    Float   @default(0)
  sgstAmount    Float   @default(0)
  igstAmount    Float   @default(0)
  vatAmount     Float   @default(0)
  tdsPercentage Float   @default(0)
  tdsAmount     Float   @default(0)
  finalAmount   Float
  pdfUrl        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    QuotationItem[]

  @@unique([companyId, quotationNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([date])
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  INVOICED
}

model QuotationItem {
  id            String  @id @default(cuid())
  quotationId   String
  description   String
  hsnSac        String?
  quantity      Float
  unitPrice     Float
  discount      Float   @default(0)
  taxPercentage Float   @default(18)
  taxableAmount Float   @default(0)
  taxAmount     Float   @default(0)
  total         Float

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String
  companyId String?
  rating    Int      // 1 to 5
  comments  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
}

model TeamInvitation {
  id        String   @id @default(cuid())
  email     String
  companyId String
  role      Role     @default(STAFF)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([companyId])
  @@index([token])
}

model AppError {
  id        String   @id @default(cuid())
  message   String
  digest    String?
  path      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model PublicFeedback {
  id        String   @id @default(cuid())
  rating    Int      // 1 to 5
  comments  String?
  source    String   // "invoice-generator", "quotation-generator", etc.
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source])
}
